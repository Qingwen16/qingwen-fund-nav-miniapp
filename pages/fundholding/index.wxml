<view class="container">

  <!-- 总资产概览 -->
  <view class="asset-header">
    <view class="asset-item">
      <text class="asset-label">总账户资产(元)</text><text class="asset-value-total">{{totalAccountAssets}}</text>
    </view>
    <view class="asset-item">
      <text class="asset-label">总当日收益</text><text class="{{totalAccountProfit >= 0 ? 'asset-value-profit' : 'asset-value-lose'}}">{{totalAccountProfit >= 0 ? '+' + totalAccountProfit : totalAccountProfit}}</text>
    </view>
  </view>

  <!-- 账户切换栏 -->
  <view class="account-tab">
    <block wx:for="{{accountList}}" wx:key="accountId">
      <view class="account-item {{currentAccountId == item.accountId ? 'active' : ''}}" bindtap="switchAccount" data-accountid="{{item.accountId}}">
        <text class="account-name">{{item.name}}</text>
        <text class="account-amount">{{item.totalAmount}}</text><text class="account-profit {{item.totalProfit < 0 ? 'loss' : 'profit'}}">{{item.totalProfit > 0 ? '+' : ''}}{{item.totalProfit}}</text>
      </view>
    </block>
  </view>

  <!-- 涨跌统计 -->
  <view class="rise-fall-stat">
    <view class="stat-item">
      <text class="rise-icon">↑</text>
      <text class="stat-num">{{riseCount}}</text>
    </view>
    <view class="stat-item">
      <text class="fall-icon">↓</text>
      <text class="stat-num">{{fallCount}}</text>
    </view>
    <view class="stat-label">
      <text>当日收益 03-27</text>
      <text>当日涨幅 03-27</text>
    </view>
  </view>

  <!-- 基金列表 -->
  <scroll-view class="fund-list" scroll-y>
    <block wx:for="{{fundList}}" wx:key="id">
      <view class="fund-item">
        <view class="fund-base-info">
          <text class="fund-name">{{item.name}}</text>
          <text class="fund-amount">{{item.amount}}</text>
        </view>
        <view class="fund-profit-info">
          <text class="fund-profit {{item.profit < 0 ? 'loss' : 'profit'}}">{{item.profit > 0 ? '+' : ''}}{{item.profit}}</text>
        </view>
        <view class="fund-ratio-info">
          <text class="fund-ratio {{item.ratio < 0 ? 'loss-bg' : 'profit-bg'}}">{{item.ratio > 0 ? '+' : ''}}{{item.ratio}}%</text>
        </view>
      </view>
    </block>
  </scroll-view>

</view>