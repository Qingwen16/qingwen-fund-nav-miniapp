<view class="container">
  <!-- 账户资产概览 -->
  <view class="asset-header">
    <view class="asset-item">
      <text class="asset-label">账户资产(元)</text>
      <text class="asset-value">{{accountAssets}}</text>
    </view>
    <view class="asset-item">
      <text class="asset-label">当日总收益</text>
      <text class="asset-value profit-loss {{totalProfitLoss < 0 ? 'loss' : 'profit'}}">{{totalProfitLoss}}</text>
    </view>
  </view>

  <!-- 涨跌统计 -->
  <view class="rise-fall-stat">
    <view class="stat-item">
      <text class="rise-icon">↑</text>
      <text class="stat-num">{{riseCount}}</text>
    </view>
    <view class="stat-item">
      <text class="fall-icon">↓</text>
      <text class="stat-num">{{fallCount}}</text>
    </view>
    <view class="stat-label">
      <text>当日收益 03-27</text>
      <text>当日涨幅 03-27</text>
    </view>
  </view>

  <!-- 基金列表 -->
  <scroll-view class="fund-list" scroll-y>
    <block wx:for="{{fundList}}" wx:key="id">
      <view class="fund-item">
        <!-- 基金名称与持仓金额 -->
        <view class="fund-base-info">
          <text class="fund-name">{{item.name}}</text>
          <text class="fund-amount">¥{{item.amount}}</text>
        </view>
        <!-- 收益与涨幅 -->
        <view class="fund-profit-info">
          <text class="fund-profit {{item.profit < 0 ? 'loss' : 'profit'}}">{{item.profit > 0 ? '+' : ''}}{{item.profit}}</text>
          <text class="fund-ratio {{item.ratio < 0 ? 'loss-bg' : 'profit-bg'}}">{{item.ratio > 0 ? '+' : ''}}{{item.ratio}}%</text>
        </view>
      </view>
    </block>
  </scroll-view>

</view>